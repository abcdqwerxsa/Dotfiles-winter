{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "modules-center": ["hyprland/workspaces"],


    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "active": "",
            "default": "",
            "empty": ""
        },
        "persistent-workspaces": {
            "*": [ 1,2,3,4,5 ]
        }
    }
        "custom/settings": {
            "format": " ",
            "tooltip": false,
            "on-click": "~/.config/hypr/settings-menu.sh",
            "on-click-right": "XDG_CURRENT_DESKTOP=GNOME gnome-control-center"
        },
} 

